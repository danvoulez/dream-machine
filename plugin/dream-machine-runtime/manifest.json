{
  "name": "dream-machine",
  "version": "0.2.0",
  "task": "T-P1+T-R2",
  "description": "Triple organelle pack: KERNEL (LogLine) + SPINE (Envelope) + FACE (membrane runtime). Seams: POST /projection (read-only), POST /oauth-crossing (L3), POST /admission/intake (proposal-only).",
  "topology_role": "manhattan",
  "entrypoints": {
    "http": {
      "method": "POST",
      "path": "/projection",
      "handler": "server/routes/projection.post.ts",
      "auth": "server/utils/projection-auth.ts"
    },
    "client": {
      "module": "agent/lib/projection-bridge.ts",
      "primary": "fetchProjectionRuntime",
      "handler": "handleProjectionPost"
    },
    "shell": {
      "script": "scripts/runtime-projection-local.py",
      "modes": ["rows", "logline", "envelope", "legacy"]
    },
    "public_api": "agent/lib/runtime-plugin.ts",
    "oauth_crossing": {
      "method": "POST",
      "path": "/oauth-crossing",
      "handler": "server/routes/oauth-crossing.post.ts",
      "module": "agent/lib/oauth-crossing.ts",
      "danger_tier": "L3",
      "process_id": "oauth-client.v1"
    },
    "admission_intake": {
      "method": "POST",
      "path": "/admission/intake",
      "handler": "server/routes/admission/intake.post.ts",
      "module": "server/utils/admission-intake.ts",
      "route_class": "proposal-only"
    }
  },
  "portal_tools": {
    "primary": "scene",
    "deprecated": ["runtime_projection"]
  },
  "normalization": {
    "portal": "agent/lib/projection-portal.ts",
    "scene": "agent/lib/scene/normalize.ts"
  },
  "organelles": {
    "face": {
      "repo": "Dream-Machine-Processual-UI",
      "role": "membrane",
      "required_files": [
        "agent/lib/projection-bridge.ts",
        "agent/lib/projection-portal.ts",
        "agent/lib/runtime-plugin.ts",
        "agent/lib/scene/readers.ts",
        "agent/tools/scene.ts",
        "server/routes/projection.post.ts",
        "server/utils/projection-auth.ts",
        "scripts/runtime-projection-local.py",
        "scripts/install-runtime.mjs",
        "plugin/dream-machine-runtime/manifest.json",
        "agent/lib/oauth-crossing.ts",
        "agent/lib/oauth-client-metadata.ts",
        "agent/lib/envelope-effect-store.ts",
        "agent/lib/board-json-v0.ts",
        "server/routes/oauth-crossing.post.ts",
        "server/routes/admission/intake.post.ts",
        "server/utils/admission-auth.ts",
        "server/utils/admission-intake.ts",
        "agent/lib/admission-client.ts"
      ]
    },
    "kernel": {
      "repo": "Dream-Machine-LogLine-Acts",
      "role": "logline",
      "required_files": [
        "lab/oauth.py",
        "lab/receipt.py",
        "processes/oauth-client.v1.yml",
        "tests/test_oauth_client.py"
      ],
      "ledger_artifacts": [".lab/lab.sqlite"]
    },
    "spine": {
      "repo": "Dream-Machine-Envelope-Ledger",
      "role": "envelope",
      "required_files": [
        "scripts/derive-from-logline.mjs",
        "src/canonical.ts",
        "src/index.ts",
        "src/board.ts",
        "dist/index.js"
      ],
      "ledger_artifacts": [".board/board.sqlite"]
    }
  },
  "required_files": [
    "agent/lib/projection-bridge.ts",
    "agent/lib/projection-portal.ts",
    "agent/lib/runtime-plugin.ts",
    "agent/lib/scene/readers.ts",
    "agent/tools/scene.ts",
    "server/routes/projection.post.ts",
    "server/utils/projection-auth.ts",
    "scripts/runtime-projection-local.py",
    "scripts/install-runtime.mjs",
    "plugin/dream-machine-runtime/manifest.json",
    "agent/lib/oauth-crossing.ts",
    "agent/lib/oauth-client-metadata.ts",
    "agent/lib/envelope-effect-store.ts",
    "agent/lib/board-json-v0.ts",
    "server/routes/oauth-crossing.post.ts",
    "server/routes/admission/intake.post.ts",
    "server/utils/admission-auth.ts",
    "server/utils/admission-intake.ts",
    "agent/lib/admission-client.ts"
  ],
  "env": [
    "DREAM_MACHINE_RUNTIME_URL",
    "DREAM_MACHINE_RUNTIME_TOKEN",
    "DREAM_MACHINE_RUNTIME_TOKEN_CLASS",
    "DREAM_MACHINE_ADMISSION_TOKEN",
    "DREAM_MACHINE_ADMISSION_TOKEN_CLASS",
    "DREAM_MACHINE_RUNTIME_SHELL_ONLY",
    "DREAM_MACHINE_RUNTIME_TIMEOUT_MS",
    "DREAM_MACHINE_LOGLINE_DB",
    "DREAM_MACHINE_ENVELOPE_DB",
    "BETTER_AUTH_URL",
    "SUPABASE_URL",
    "SUPABASE_PROJECT_REF",
    "SUPABASE_SECRET_KEY"
  ],
  "verify": {
    "face": {
      "install": "pnpm install:runtime",
      "motor": "pnpm test",
      "contracts": "pnpm contracts:validate"
    },
    "kernel": {
      "test": {
        "python": ".venv/bin/python",
        "module": "pytest",
        "args": [
          "tests/test_oauth_client.py",
          "-q",
          "-k",
          "not (runnable or evaluator_resolves or enqueues)"
        ]
      }
    },
    "spine": {
      "build": "pnpm build",
      "test": "pnpm test"
    }
  }
}