# Ring 3 — LAB 8GB engine room (runtime API)
# Copy to /Lab/env/runtime.env on the LAB machine
# Template: docs/dream-machine-hybrid-topology.v0.yml

DREAM_MACHINE_LOGLINE_DB=/Lab/data/lab.sqlite
DREAM_MACHINE_ENVELOPE_DB=/Lab/data/board.sqlite
DREAM_MACHINE_RUNTIME_TOKEN=

# Local listener (Canyon tunnel exposes this to api.lab.minilab.work)
PORT=3000
HOST=127.0.0.1

# For local evals on LAB only (not required for /projection API)
# AI_GATEWAY_API_KEY=

# OAuth crossing execute (optional — only if running full portal on LAB)
# SUPABASE_URL=
# SUPABASE_PROJECT_REF=
# SUPABASE_SECRET_KEY=