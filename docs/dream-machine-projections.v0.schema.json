{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dream-machine-projections.v0.schema.json",
  "title": "Dream Machine Projection Response v0",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "projection_id",
    "intent",
    "jurisdiction",
    "authoritative",
    "freshness",
    "source_refs",
    "blocks",
    "warnings",
    "affordances",
    "cannot_do"
  ],
  "properties": {
    "projection_id": {
      "type": "string",
      "minLength": 1
    },
    "intent": {
      "type": "string",
      "enum": [
        "overview",
        "arrival_detail",
        "process_detail",
        "waiting_on_me",
        "open_findings",
        "proposal_detail",
        "board_act_detail",
        "logline_receipt_detail",
        "danger_review",
        "changes_since"
      ]
    },
    "jurisdiction": {
      "type": "string",
      "enum": [
        "logline",
        "envelope",
        "membrane",
        "mixed"
      ]
    },
    "authoritative": {
      "const": false
    },
    "freshness": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "generated_at",
        "as_of",
        "stale"
      ],
      "properties": {
        "generated_at": {
          "type": "string",
          "minLength": 1
        },
        "as_of": {
          "type": [
            "object",
            "string"
          ]
        },
        "stale": {
          "type": "boolean"
        },
        "ttl_ms": {
          "type": "number",
          "minimum": 0
        },
        "rebuild_reason": {
          "type": "string"
        }
      }
    },
    "source_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "blocks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection_block"
      }
    },
    "open_findings": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/projection_warning"
      }
    },
    "affordances": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true
      }
    },
    "cannot_do": {
      "type": "array",
      "minItems": 3,
      "contains": {
        "const": "register_receipt"
      },
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  },
  "$defs": {
    "source_ref": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "ref_kind",
        "ref",
        "owner"
      ],
      "properties": {
        "ref_kind": {
          "type": "string",
          "minLength": 1
        },
        "ref": {
          "type": "string",
          "minLength": 1
        },
        "owner": {
          "type": "string",
          "enum": [
            "logline",
            "envelope",
            "membrane",
            "processual_ui"
          ]
        }
      }
    },
    "projection_block": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "block_id",
        "kind",
        "title",
        "body",
        "source_refs"
      ],
      "properties": {
        "block_id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "summary",
            "source_ref",
            "proposal",
            "board_act",
            "logline_receipt",
            "finding",
            "attention",
            "risk_note",
            "warning",
            "next_step",
            "divider"
          ]
        },
        "title": {
          "type": "string"
        },
        "body": {
          "type": "string"
        },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "risk_tier": {
          "type": "string"
        },
        "authority_route": {
          "type": "object"
        },
        "display_priority": {
          "type": "integer"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "kind": {
                "const": "divider"
              }
            }
          },
          "then": true,
          "else": {
            "properties": {
              "source_refs": {
                "minItems": 1
              }
            }
          }
        }
      ]
    },
    "projection_warning": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "kind",
        "message",
        "source_refs"
      ],
      "properties": {
        "kind": {
          "type": "string",
          "enum": [
            "stale_projection",
            "partial_source",
            "mixed_jurisdiction",
            "envelope_only",
            "requires_logline_registration",
            "l5_describe_only",
            "missing_grant",
            "unresolved_finding"
          ]
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "source_refs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}

