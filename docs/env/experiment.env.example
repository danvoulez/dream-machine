# Ring 1 — Vercel Preview (experiment lab)
# Apply to BOTH web and eve services · Scope: Preview
# Template: docs/dream-machine-hybrid-topology.v0.yml

BETTER_AUTH_SECRET=
# Set after first preview deploy — use the generated *.vercel.app URL
BETTER_AUTH_URL=https://dream-machine-portal-git-BRANCH-TEAM.vercel.app
NUXT_PUBLIC_SITE_URL=https://dream-machine-portal-git-BRANCH-TEAM.vercel.app
INTERNAL_API_SECRET=

# Prefer Neon branch for isolated preview data (optional)
DATABASE_URL=postgresql://USER:PASS@HOST/app?sslmode=require

# --- Runtime mode (pick one profile) ---

# Profile A: stub lab (default for most PRs — UI/normalizer only)
DREAM_MACHINE_RUNTIME_SHELL_ONLY=1

# Profile B: live-read lab (uncomment for integration PRs)
# DREAM_MACHINE_RUNTIME_SHELL_ONLY=0
# DREAM_MACHINE_RUNTIME_URL=https://api.lab.minilab.work
# DREAM_MACHINE_RUNTIME_TOKEN=

# Acceptance harness routes (/acceptance/*) — OK on Preview
DREAM_MACHINE_ACCEPTANCE=1

# AI: Vercel AI Gateway OIDC on preview (same as cockpit)