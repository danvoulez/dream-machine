# Realtime listener config for runtime/receiver/realtime_listener.mjs
# Copy to .env (and keep .env out of git).

SUPABASE_URL=https://dtmhymciiwinnjhljozl.supabase.co

# MUST be the service_role secret, NOT the publishable key.
# public.logline_acts has RLS enabled with no policies, so anon/publishable
# subscribers receive zero events. service_role bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...
