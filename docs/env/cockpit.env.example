# Ring 2 — Vercel Production (cockpit)
# Apply to BOTH web and eve services · Scope: Production
# Template: docs/dream-machine-hybrid-topology.v0.yml

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=https://dream-machine-portal.vercel.app
NUXT_PUBLIC_SITE_URL=https://dream-machine-portal.vercel.app
INTERNAL_API_SECRET=

# Neon app database (portal auth, threads, memory)
DATABASE_URL=postgresql://USER:PASS@HOST/app?sslmode=require

# Read ledgers from LAB engine room (Ring 3)
DREAM_MACHINE_RUNTIME_URL=https://api.lab.minilab.work
DREAM_MACHINE_RUNTIME_TOKEN=
DREAM_MACHINE_RUNTIME_TIMEOUT_MS=8000

# AI: Vercel AI Gateway via project OIDC — leave AI_GATEWAY_API_KEY unset on Vercel prod

# Identity seam (C0.2) — external ids map to passport_hash only; lab:* is display gloss via LAB_ID_MAP
# DREAM_MACHINE_PASSPORT_MAP={"vercel-user-id":"<64-char content_hash>","user@example.com":"<64-char>"}
# DREAM_MACHINE_DEFAULT_PASSPORT_HASH=<64-char content_hash>  # explicit fallback when unmapped
# DREAM_MACHINE_LAB_ID_MAP={"vercel-user-id":"lab:dan"}     # display only — never authority

# Never on production cockpit:
# DREAM_MACHINE_ACCEPTANCE=1
# DREAM_MACHINE_RUNTIME_SHELL_ONLY=1