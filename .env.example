# Better Auth — generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=change-me-to-a-random-string-at-least-32-chars
BETTER_AUTH_URL=http://localhost:3000

# Shared secret for Eve agent ↔ Nuxt internal API (memory, Slack link).
# Must match on both the Nuxt app and the Eve service in production.
INTERNAL_API_SECRET=change-me-to-a-random-string-at-least-32-chars

# Optional — canonical URL for SEO (Open Graph, canonical links)
# NUXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Optional — required for T-P2 agent eval (`pnpm test:eval`) and live Eve turns locally
# AI_GATEWAY_API_KEY=your-vercel-ai-gateway-key

# Optional — local-only acceptance routes (/acceptance/scene, /acceptance/chat). Ignored when NODE_ENV=production.
# DREAM_MACHINE_ACCEPTANCE=1

# Optional — portal identity bridge (T-F5): map app user id → LAB operator id
# DREAM_MACHINE_LAB_ID_MAP={"user-id-here":"lab:dan"}
# DREAM_MACHINE_DEFAULT_LAB_ID=lab:operator
# DREAM_MACHINE_OPERATOR_GRANTS=grant:observe,grant:scene

# Optional — T-P1 runtime plugin: pnpm install:runtime (check) · pnpm pack:runtime (seal)
# Optional — projection runtime HTTP (T-R1). Scene + legacy tools POST here instead of shelling python.
# Defaults to BETTER_AUTH_URL when unset. Set DREAM_MACHINE_RUNTIME_SHELL_ONLY=1 to force the python bridge.
# DREAM_MACHINE_RUNTIME_URL=http://localhost:3000
# DREAM_MACHINE_RUNTIME_TOKEN=change-me-runtime-bearer
# DREAM_MACHINE_RUNTIME_TIMEOUT_MS=8000

# T-R2 OAuth crossing (POST /oauth-crossing) — execute mode only; dry-run needs no secrets
# SUPABASE_PROJECT_REF=your-project-ref
# SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SECRET_KEY=your-service-role-key
