{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Dream Machine Answer",
  "type": "object",
  "required": ["question", "answer", "confidence", "evidence", "contradictions", "unknowns", "actions"],
  "properties": {
    "question": {"type": "string"},
    "answer": {"type": "string"},
    "confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "evidence": {"type": "array", "items": {"type": "object", "required": ["ref", "summary"], "properties": {"ref": {"type": "string", "pattern": "^(source|artifact|extraction|chunk|claim|map|act):"}, "summary": {"type": "string"}}, "additionalProperties": false}},
    "contradictions": {"type": "array", "items": {"type": "string"}},
    "unknowns": {"type": "array", "items": {"type": "string"}},
    "actions": {"type": "array", "items": {"type": "string"}},
    "candidate_artifacts": {"type": "array", "items": {"type": "string"}}
  },
  "additionalProperties": false
}
