{
  "name": "dream-machine-processual-ui",
  "version": "0.0.0",
  "description": "Dream Machine Processual UI: the portal chief over LogLine and Envelope.",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@9.15.0",
  "type": "module",
  "imports": {
    "#*": "./agent/*"
  },
  "scripts": {
    "build": "nuxt build",
    "dev": "node scripts/ensure-eve-dev.mjs && nuxt dev",
    "start": "nuxt preview",
    "typecheck": "nuxt typecheck",
    "test": "node scripts/run-tests.mjs",
    "test:e2e": "playwright test",
    "test:e2e:chat": "playwright test e2e/portal-chat-scene.spec.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:eval": "node scripts/run-eval.mjs",
    "seed:lab-queue": "node scripts/seed-lab-queue.mjs",
    "install:runtime": "node scripts/install-runtime.mjs",
    "install:runtime:seed": "node scripts/install-runtime.mjs --seed",
    "test:projection": "node scripts/test-runtime-projection.mjs",
    "contracts:validate": "node scripts/validate-dream-machine-contracts.mjs",
    "db:generate": "nuxt db generate",
    "db:migrate": "nuxt db migrate"
  },
  "dependencies": {
    "@comark/nuxt": "^0.4.0",
    "@libsql/client": "^0.17.3",
    "@nuxt/ui": "^4.8.2",
    "@nuxthub/core": "^0.10.7",
    "@shikijs/langs": "^4.2.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/connect": "0.2.3",
    "ai": "^7.0.0",
    "better-auth": "^1.6.18",
    "chat": "^4.31.0",
    "chat-adapter-sendblue": "^0.2.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "eve": "^0.13.8",
    "maska": "^3.2.0",
    "nuxt": "^4.4.8",
    "shiki": "^4.2.0",
    "tailwindcss": "^4.3.0",
    "vue": "^3.5.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@iconify-json/lucide": "^1.2.112",
    "@iconify-json/simple-icons": "^1.2.48",
    "@types/node": "25.9.1",
    "typescript": "^5.9.3",
    "vue-tsc": "^2.2.12"
  }
}
